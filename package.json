{
  "name": "senza-roaming",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev --config apps/web/dist/server/wrangler.json",
    "dev:astro": "astro dev --root apps/web",
    "build": "astro build --root apps/web",
    "smoke:runtime": "node scripts/smoke-astro-runtime.mjs && npm run smoke:public-shell && npm run smoke:public-homepage-candidate && npm run smoke:public-trust-pages",
    "smoke:public-shell": "node scripts/smoke-public-shell.mjs",
    "smoke:public-homepage-candidate": "node scripts/smoke-public-homepage-candidate.mjs",
    "smoke:public-trust-pages": "node scripts/smoke-public-trust-pages.mjs",
    "smoke:ui": "node scripts/smoke-control-room-ui.mjs && npm run smoke:brief-decisions",
    "smoke:brief-decisions": "node scripts/run-smoke-control-room-brief-decisions.mjs",
    "smoke:claims": "node scripts/smoke-control-room-claims.mjs",
    "smoke:readiness": "node scripts/smoke-control-room-readiness.mjs",
    "smoke:drafts": "node scripts/smoke-control-room-drafts.mjs",
    "smoke:draft-detail": "node scripts/smoke-control-room-draft-detail.mjs",
    "smoke:queue-audit": "node scripts/smoke-control-room-queue-audit.mjs && npm run smoke:legacy-parity",
    "smoke:legacy-parity": "node scripts/smoke-control-room-legacy-parity.mjs",
    "smoke:quality": "node scripts/smoke-research-quality.mjs",
    "eval:research-quality": "node scripts/evaluate-research-quality-golden.mjs",
    "test:runtime": "npm run build && npm run db:migrate:local && npm run smoke:runtime",
    "test:ui": "npm run build && npm run db:migrate:local && npm run smoke:ui && npm run smoke:claims && npm run smoke:readiness && npm run smoke:drafts && npm run smoke:draft-detail && npm run smoke:queue-audit",
    "deploy": "npm run build && wrangler deploy --config apps/web/dist/server/wrangler.json",
    "typecheck": "astro check --root apps/web && tsc --noEmit",
    "types": "wrangler types src/worker-configuration.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "keywords:intake": "node scripts/build-keyword-research.mjs",
    "research:ingest": "node scripts/ingest-last30days.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.3",
    "@astrojs/react": "6.0.1",
    "@cloudflare/containers": "0.3.7",
    "astro": "7.1.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "22.20.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "wrangler": "4.112.0"
  }
}
