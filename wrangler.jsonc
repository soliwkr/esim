{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "senza-roaming",
  "main": "apps/web/src/worker.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./apps/web/dist/client",
    "binding": "ASSETS",
    "run_worker_first": [
      "/astro-foundation",
      "/astro-foundation/*",
      "/control-room-foundation",
      "/control-room-foundation/*"
    ]
  },
  "observability": {
    "enabled": true
  },
  "secrets": {
    "required": [
      "MAINTENANCE_TOKEN",
      "AI_GATEWAY_TOKEN"
    ]
  },
  "vars": {
    "SITE_NAME": "Senza Roaming",
    "SITE_URL": "https://senzaroaming.it",
    "GTM_ID": "",
    "AFFILIATE_MODE": "disabled",
    "CLOUDFLARE_ACCOUNT_ID": "60496826f56a093a72602bfae074fdcf",
    "AI_GATEWAY_ID": "senza-roaming-ai",
    "GOOGLE_VERTEX_PROJECT_ID": "soliwkr",
    "GOOGLE_VERTEX_PROJECT_NUMBER": "739710211590",
    "GOOGLE_VERTEX_LOCATION": "global",
    "GOOGLE_VERTEX_MODEL": "gemini-3.1-flash-lite"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "senza-roaming",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  "containers": [
    {
      "class_name": "Last30DaysContainer",
      "image": "./containers/last30days/Dockerfile",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "LAST30DAYS_CONTAINER",
        "class_name": "Last30DaysContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "Last30DaysContainer"
      ]
    }
  ],
  "workflows": [
    {
      "name": "senza-roaming-recent-demand",
      "binding": "RECENT_DEMAND_WORKFLOW",
      "class_name": "RecentDemandWorkflow",
      "schedules": [
        "0 5 * * MON",
        "0 5 * * THU"
      ]
    }
  ]
}
