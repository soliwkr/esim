---
import PublicFooter from '../components/public/PublicFooter.astro'
import PublicHeader from '../components/public/PublicHeader.astro'
import { setPublicPreviewResponseHeaders } from '../lib/public-preview-response'
import type { PublicJsonLdDocument, PublicOpenGraphType } from '../../../../src/public-seo'
import { serializeJsonLd } from '../../../../src/public-seo'
import '../styles/public.css'

interface Props {
  title: string
  description: string
  canonicalPath: string
  noindex?: boolean
  previewBase?: string
  siteName?: string
  ogType?: PublicOpenGraphType
  schema?: PublicJsonLdDocument | PublicJsonLdDocument[]
}

const {
  title,
  description,
  canonicalPath,
  noindex = false,
  previewBase,
  siteName = 'Senza Roaming',
  ogType = 'website',
  schema,
} = Astro.props

const base = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(canonicalPath, base).toString()
const robots = noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'
const schemaJson = schema ? serializeJsonLd(schema) : null

if (noindex) {
  setPublicPreviewResponseHeaders(Astro.response.headers)
}
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="theme-color" content="#073f43" />
    <title>{title}</title>
    {schemaJson && <script type="application/ld+json" set:html={schemaJson}></script>}
  </head>
  <body>
    <a class="skip-link" href="#contenuto">Vai al contenuto</a>
    <PublicHeader previewBase={previewBase} />
    <main id="contenuto" tabindex="-1">
      <slot />
    </main>
    <PublicFooter previewBase={previewBase} />
  </body>
</html>
