---
import type { FaqItem } from '../../../../../src/types'

interface Props {
  items: FaqItem[]
}

const { items } = Astro.props
---

{items.length > 0 && (
  <section class="article-faq" aria-labelledby="article-faq-title" data-article-faq>
    <p class="eyebrow">Domande frequenti</p>
    <h2 id="article-faq-title">Dubbi prima della partenza</h2>
    <div class="article-faq-list">
      {items.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
