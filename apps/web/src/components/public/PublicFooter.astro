---
interface Props {
  previewBase?: string
}

const { previewBase } = Astro.props
const year = new Date().getUTCFullYear()
const trustHref = (slug: string) => previewBase ? `${previewBase}/${slug}` : `/${slug}`
---

<footer class="site-footer">
  <div class="public-container footer-grid">
    <div>
      <p class="footer-brand">Senza Roaming</p>
      <p class="footer-note">
        Guide italiane per capire compatibilità, dati, durata, hotspot, attivazione e limiti delle eSIM prima della partenza.
      </p>
    </div>

    <nav aria-label="Trasparenza e informazioni">
      <p class="footer-heading">Come lavoriamo</p>
      <a href={trustHref('metodo')}>Metodo editoriale</a>
      <a href={trustHref('trasparenza')}>Trasparenza</a>
      <a href={trustHref('privacy')}>Privacy</a>
    </nav>

    <div>
      <p class="footer-heading">Stato commerciale</p>
      <p class="footer-note">
        Le affiliazioni restano disabilitate finché disclosure, misurazione e controlli non sono pronti.
      </p>
    </div>
  </div>

  <div class="public-container footer-bottom">
    <span>© {year} Senza Roaming</span>
    <span>Contenuti revisionati, nessuna pubblicazione autonoma dell’AI.</span>
  </div>
</footer>
