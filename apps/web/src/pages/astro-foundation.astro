---
import { env } from 'cloudflare:workers'
import { loadPublicHomepageCards } from '../../../../src/public-page-cards'
import PublicPageCardGrid from '../components/public/PublicPageCardGrid.astro'
import PublicLayout from '../layouts/PublicLayout.astro'

// PublicLayout owns the noindex, nofollow response contract for every preview route.
// D1 is read only on the server; no binding or catalog payload is exposed to browser code.
const { featured, destinations } = await loadPublicHomepageCards(env.DB)
---

<PublicLayout
  title="Senza Roaming — homepage Astro candidate"
  description="Preview non indicizzabile della futura homepage Astro di Senza Roaming, alimentata soltanto dal catalogo pubblicato."
  canonicalPath="/astro-foundation"
  previewBase="/astro-foundation"
  noindex
>
  <div class="preview-band" data-public-shell="astro-preview" data-homepage-candidate>
    Preview Astro · non indicizzata · il sito pubblico attuale non cambia
  </div>

  <section class="public-hero" aria-labelledby="hero-title">
    <div class="public-container hero-grid">
      <div>
        <p class="eyebrow">Internet in viaggio, senza improvvisare</p>
        <h1 id="hero-title">Trova la eSIM giusta prima di partire.</h1>
        <p class="hero-lead">
          Guide italiane su destinazioni, telefoni compatibili e provider. Mettiamo in ordine dati,
          durata, hotspot, attivazione e limiti reali senza fingere che un piano vada bene per tutti.
        </p>
        <div class="hero-actions">
          <a class="public-button" href="/astro-foundation/destinazioni">Scegli la destinazione</a>
          <a class="public-button secondary" href="/astro-foundation/guide">Capisci come funziona</a>
        </div>
      </div>

      <aside class="decision-card" aria-labelledby="decision-title">
        <p class="card-kicker">Prima della scelta</p>
        <h2 id="decision-title">Quattro domande valgono più di cento offerte.</h2>
        <ol class="decision-list">
          <li><span>1</span><div>Il telefono supporta davvero la eSIM?</div></li>
          <li><span>2</span><div>Dove andrai e per quanti giorni?</div></li>
          <li><span>3</span><div>Quanti dati, hotspot e chiamate ti servono?</div></li>
          <li><span>4</span><div>Quali limiti sono dichiarati nelle condizioni?</div></li>
        </ol>
      </aside>
    </div>
  </section>

  <section class="public-section" aria-labelledby="start-title">
    <div class="public-container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Da dove iniziare</p>
          <h2 id="start-title">Una strada diversa per ogni domanda.</h2>
        </div>
        <p>
          Non moltiplichiamo pagine cambiando soltanto il nome di un Paese. Ogni sezione deve aiutare
          una decisione distinta e restare utile anche senza acquistare nulla.
        </p>
      </div>

      <div class="route-grid">
        <a class="route-card" href="/astro-foundation/destinazioni">
          <span class="route-index">01 · DOVE VAI</span>
          <h3>Destinazioni</h3>
          <p>Parti dal Paese, dalla durata del viaggio e dalle condizioni che possono cambiare sul posto.</p>
          <span class="route-arrow">Esplora le destinazioni →</span>
        </a>

        <a class="route-card" href="/astro-foundation/guide">
          <span class="route-index">02 · COME FUNZIONA</span>
          <h3>Guide pratiche</h3>
          <p>Compatibilità, installazione, attivazione, hotspot, consumi e problemi prima della partenza.</p>
          <span class="route-arrow">Leggi le guide →</span>
        </a>

        <a class="route-card" href="/astro-foundation/confronti">
          <span class="route-index">03 · COSA CAMBIA</span>
          <h3>Confronti</h3>
          <p>Metti a confronto opzioni e limiti senza trasformare una commissione in una classifica automatica.</p>
          <span class="route-arrow">Vai ai confronti →</span>
        </a>
      </div>
    </div>
  </section>

  <PublicPageCardGrid
    id="featured-guides"
    eyebrow="Dal catalogo pubblicato"
    title="Guide essenziali"
    description="Soltanto pagine già pubblicate entrano in questa selezione. Draft e contenuti in review restano esclusi."
    items={featured}
  />

  <PublicPageCardGrid
    id="main-destinations"
    eyebrow="Partenze frequenti"
    title="Destinazioni principali"
    description="Guide pubblicate organizzate per destinazione, ordinate dallo stesso read model usato dal sito corrente."
    items={destinations}
  />

  <section class="public-section method-section" aria-labelledby="method-title">
    <div class="public-container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Il metodo</p>
          <h2 id="method-title">La pagina arriva dopo le prove.</h2>
        </div>
        <p>
          Un testo può essere chiaro e ancora non essere pubblicabile. Fonti, claim, scadenze e revisione
          restano passaggi distinti.
        </p>
      </div>

      <div class="method-grid">
        <article class="method-step">
          <span>01</span>
          <h3>Domanda reale</h3>
          <p>Partiamo da un problema o da un intento riconoscibile, non dal bisogno di creare nuove URL.</p>
        </article>
        <article class="method-step">
          <span>02</span>
          <h3>Fonti datate</h3>
          <p>Prezzo, durata, rete, hotspot e fair use richiedono una fonte identificabile e una data.</p>
        </article>
        <article class="method-step">
          <span>03</span>
          <h3>Claim separati</h3>
          <p>Ogni fatto viene verificato singolarmente. Un claim insufficiente non alimenta il testo fattuale.</p>
        </article>
        <article class="method-step">
          <span>04</span>
          <h3>Revisione umana</h3>
          <p>Brief accettato, draft approvato e pagina pubblicata rimangono tre decisioni diverse.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="public-section trust-section" aria-labelledby="trust-title">
    <div class="public-container trust-grid">
      <div class="trust-copy">
        <p class="eyebrow">Trasparenza operativa</p>
        <h2 id="trust-title">Meno promesse. Più stato visibile.</h2>
        <p>
          Questa preview mostra il futuro involucro pubblico. Non pubblica contenuti in review, non attiva
          affiliazioni e non sostituisce ancora il renderer corrente.
        </p>
      </div>

      <ul class="trust-list">
        <li>
          <strong>Nessuna pubblicazione autonoma</strong>
          <span>L’AI può aiutare ricerca e draft, ma non promuove una pagina a pubblicata.</span>
        </li>
        <li>
          <strong>Informazioni con scadenza</strong>
          <span>Le condizioni commerciali vengono trattate come dati verificati in un momento preciso.</span>
        </li>
        <li>
          <strong>Affiliazioni ancora disabilitate</strong>
          <span>Monetizzazione, disclosure e misurazione devono essere pronte insieme.</span>
        </li>
        <li>
          <strong>Preview isolata</strong>
          <span>L’apice e tutte le route canoniche continuano a essere servite dal sistema pubblico esistente.</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="cta-title">
    <div class="public-container cta-panel">
      <div>
        <h2 id="cta-title">Vuoi vedere come controlliamo le informazioni?</h2>
        <p>
          Il metodo editoriale descrive cosa può diventare un fatto pubblico, cosa resta escluso e perché
          un draft approvato non equivale a una pagina pubblicata.
        </p>
      </div>
      <a class="public-button" href="/astro-foundation/metodo">Leggi il metodo</a>
    </div>
  </section>
</PublicLayout>
