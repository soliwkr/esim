---
import { RuntimeBadge } from '../components/RuntimeBadge';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Astro frontend foundation | Senza Roaming</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Senza Roaming · spike non pubblico</p>
      <h1>Astro e backend condividono lo stesso Worker.</h1>
      <p>
        Questa pagina verifica la fondazione Astro. API, D1, Workflow, Container,
        AI e gate editoriali restano nell'execution plane esistente.
      </p>
      <RuntimeBadge client:idle />
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    color: #16201d;
    background: #f4f1e9;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
  main {
    width: min(42rem, 100%);
    padding: clamp(2rem, 7vw, 4.5rem);
    border: 1px solid #c8c1b4;
    border-radius: 1.5rem;
    background: #fffdf8;
    box-shadow: 0 1.5rem 4rem rgb(31 45 39 / 10%);
  }
  .eyebrow {
    margin: 0 0 1rem;
    color: #6d756f;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  h1 { margin: 0; font-size: clamp(2rem, 6vw, 3.4rem); line-height: 1.02; }
  p { line-height: 1.65; }
  :global(.runtime-badge) {
    display: inline-flex;
    margin-top: 1rem;
    padding: .55rem .8rem;
    border-radius: 999px;
    color: #f8fff9;
    background: #17613f;
    font-size: .85rem;
    font-weight: 700;
  }
</style>
